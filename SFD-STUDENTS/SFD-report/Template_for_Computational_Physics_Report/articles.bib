% BAYARJARGAL201831
@article{Bayarjargal_phase_diagr_VII,
title = {{{CaCO$_3$}} phase diagram studied with {R}aman spectroscopy at pressures up to 50 {GPa} and high temperatures and {DFT} modeling},
journal = {Physics of the Earth and Planetary Interiors},
volume = {281},
pages = {31-45},
year = {2018},
issn = {0031-9201},
url = {https://www.sciencedirect.com/science/article/pii/S0031920117303278},
author = {L. Bayarjargal and C.-J. Fruhner and N. Schrodt and B. Winkler},
keywords = {Phase diagram, Calcium carbonate, Phase transition},
abstract = {We revise the high pressure, high temperature phase diagram of {CaCO$_3$} using Raman spectroscopy in conjunction with laser heated diamond anvil cell experiments. We confirm numerous aspects of earlier studies, including a recent {X}-ray diffraction study about the stability field of {CaCO$_3$}-VII. Our Raman results show that {CaCO$_3$}-VII is stable in the lower mantle at a depth of 690–1010 km. Our DFT calculations show that the phase transition from aragonite to {CaCO$_3$}-VII at ≈25 GPa and from {CaCO$_3$}-VII to post-aragonite at ≈40 GPa are accompanied by density changes of 2% and 3.5%, respectively. Shear sound velocities change by 9% and −12% across the transitions, respectively. Hence, a sufficient amount, at least locally, of {CaCO$_3$} in the Earth’s mantle can be detectable by an increase of the shear velocity at 690km and a decrease of the shear velocity at 1010 km depths.}
}

